<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
        Exclude EncryptedSharedPreferences for connections.
        The Keystore key is device-bound — backed-up credentials cannot be decrypted
        on another device, causing silent data loss on device restore.
    -->
    <exclude domain="sharedpref" path="secure_connections.xml" />
</full-backup-content>
