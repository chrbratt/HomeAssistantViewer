<?xml version="1.0" encoding="utf-8"?>
<!--
  Flat, theme-independent app logo used in the dashboard top app bar.
  Mirrors the launcher icon design but bakes the background into a single
  drawable so it renders correctly in light/dark themes and on Android
  versions that don't honour adaptive-icon masking inside `painterResource`.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="32dp"
    android:height="32dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Slate-900 navy disc, matches the launcher background -->
    <path
        android:fillColor="#0F172A"
        android:pathData="M54,0 A54,54 0 1,0 54,108 A54,54 0 1,0 54,0 Z" />

    <!-- House outline (same geometry as the launcher foreground) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 54,26 L 26,48 L 26,80 L 82,80 L 82,48 Z" />

    <!-- Switch track -->
    <path
        android:strokeColor="#475569"
        android:strokeWidth="14"
        android:strokeLineCap="round"
        android:pathData="M 46,62 L 62,62" />

    <!-- Switch knob in "ON" position (Home Assistant blue) -->
    <path
        android:fillColor="#03A9F4"
        android:pathData="M 62,57 A 5,5 0 1 0 62,67 A 5,5 0 1 0 62,57 Z" />

</vector>
